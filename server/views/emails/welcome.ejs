<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Welcome to NeuraExplain</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #4a6cf7; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { padding: 20px; background-color: #f9f9f9; border: 1px solid #ddd; border-top: none; border-radius: 0 0 5px 5px; }
        .button {
            display: inline-block; padding: 10px 20px; background-color: #4a6cf7; color: white; text-decoration: none;
            border-radius: 5px; margin: 20px 0;
        }
        .footer { margin-top: 20px; font-size: 12px; color: #777; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Welcome to NeuraExplain!</h1>
        </div>
        <div class="content">
            <p>Hello <%= name %>,</p>
            <p>Thank you for registering with NeuraExplain. We're excited to have you on board!</p>
            
            <% if (verificationUrl) { %>
                <p>Please verify your email address by clicking the button below:</p>
                <p style="text-align: center;">
                    <a href="<%= verificationUrl %>" class="button">Verify Email Address</a>
                </p>
                <p>Or copy and paste this link into your browser:</p>
                <p><%= verificationUrl %></p>
            <% } %>
            
            <p>If you did not create an account with us, please ignore this email.</p>
            
            <p>Best regards,<br>The NeuraExplain Team</p>
        </div>
        <div class="footer">
            <p>© <%= new Date().getFullYear() %> NeuraExplain. All rights reserved.</p>
            <p>This is an automated message, please do not reply directly to this email.</p>
        </div>
    </div>
</body>
</html>
